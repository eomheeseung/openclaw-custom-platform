# ─────────────────────────────────────────────────────────────
#  OpenClaw Custom Platform — Environment Variables
#  Copy to .env and fill in values. .env is gitignored.
# ─────────────────────────────────────────────────────────────

# ───── Google OAuth (Drive / Gmail / Calendar) ─────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost/oauth/google/callback

# Domain restriction (only allow this email domain to log in via Google)
ALLOWED_DOMAIN=example.com

# ───── AI Model API Keys ─────
# At least one is required. kimi-k2.5 (Moonshot) is the default in BOOTSTRAP.md
MOONSHOT_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ───── Public Domain (optional) ─────
# Used for HTTPS proxy and OAuth callback URLs in production
DOMAIN=localhost
